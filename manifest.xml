<?xml version="1.0" encoding="UTF-8"?>
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application
        entry="LumenApp"
        id="43dbe389ef9246dfb35865cc054599d5"
        launcherIcon="@Drawables.LauncherIcon"
        minApiLevel="3.2.0"
        name="@Strings.AppName"
        type="watchface">

        <!-- Modern AMOLED + MIP devices. Add/remove freely (VS Code:
             "Monkey C: Edit Products" keeps these in sync with your SDK). -->
        <!-- Round AMOLED devices, grouped by screen resolution (each gets its
             own font size via resources-round-WxH/). MIP and rectangular watches
             are intentionally excluded. -->
        <iq:products>
            <!-- 360x360 -->
            <iq:product id="venu2s"/>
            <iq:product id="fr265s"/>
            <!-- 390x390 -->
            <iq:product id="venu441mm"/>
            <iq:product id="venu3s"/>
            <iq:product id="vivoactive5"/>
            <iq:product id="vivoactive6"/>
            <iq:product id="fr165"/>
            <iq:product id="fr170"/>
            <iq:product id="epix2pro42mm"/>
            <iq:product id="marq2"/>
            <!-- 416x416 -->
            <iq:product id="venu2"/>
            <iq:product id="venu2plus"/>
            <iq:product id="fr265"/>
            <iq:product id="epix2"/>
            <iq:product id="epix2pro47mm"/>
            <iq:product id="fenix843mm"/>
            <iq:product id="d2airx10"/>
            <iq:product id="d2mach1"/>
            <!-- 454x454 -->
            <iq:product id="venu445mm"/>
            <iq:product id="venu3"/>
            <iq:product id="fr965"/>
            <iq:product id="fr970"/>
            <iq:product id="epix2pro51mm"/>
            <iq:product id="fenix847mm"/>
            <iq:product id="fenix8pro47mm"/>
            <iq:product id="d2mach2pro"/>
        </iq:products>

        <!-- UserProfile: read resting heart rate. Clock, battery, steps, current
             heart rate and date need no permission. -->
        <iq:permissions>
            <iq:uses-permission id="UserProfile"/>
        </iq:permissions>

        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
